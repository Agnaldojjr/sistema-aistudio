rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic global safety net: reject everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Patients Collection Rules
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }

    // Appointments Collection Rules
    match /appointments/{appointmentId} {
      allow read, write: if request.auth != null;
    }

    // Clinical History Collection Rules
    match /clinical_history/{historyId} {
      allow read, write: if request.auth != null;
    }

    // Communications Collection Rules
    match /communications/{commId} {
      allow read, write: if request.auth != null;
    }
  }
}

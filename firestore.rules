rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public anamnesis: allow create from unauthenticated/anonymous users,
    // but only authenticated users can read/update/delete
    match /public_anamnesis/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // All other collections require authentication AND ownership
    match /{document=**} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
